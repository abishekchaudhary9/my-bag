NODE_ENV=development
PORT=5000

# Comma-separated frontend origins allowed by CORS.
CLIENT_URL=http://localhost:5173,http://localhost:8080

# Required in production.
MONGODB_URI=mongodb+srv://user:password@cluster.example.net/maison_db?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret

# Firebase Admin, choose either FIREBASE_SERVICE_ACCOUNT or the individual fields.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional service integrations.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=maison-products
GEMINI_API_KEY=
KHALTI_SECRET_KEY=

# Optional email integration.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
